---
interface Props {
  caption?: string;
}

const { caption } = Astro.props;
---

<figure class="harness-runtime">
  <div class="runtime-sheet">
    <pre
      class="runtime-sheet__pre"><code><span class="runtime-sheet__key">instructions</span>:
  <span class="runtime-sheet__item">-</span> understand the codebase before editing
  <span class="runtime-sheet__item">-</span> keep diffs focused and explain tradeoffs
  <span class="runtime-sheet__item">-</span> run targeted checks before declaring success
  <span class="runtime-sheet__item">-</span> follow merged project rules from <span class="runtime-sheet__path">AGENTS.md</span> and <span class="runtime-sheet__path">instructions[]</span>

<span class="runtime-sheet__key">context</span>:
  <span class="runtime-sheet__subkey">working_directory</span>: <span class="runtime-sheet__path">~/code/acme/shop-frontend</span>
  <span class="runtime-sheet__subkey">project_state</span>:
    <span class="runtime-sheet__item">-</span> repository files
    <span class="runtime-sheet__item">-</span> git diff
    <span class="runtime-sheet__item">-</span> command output
    <span class="runtime-sheet__item">-</span> failing tests

<span class="runtime-sheet__key">tools</span>:
  <span class="runtime-sheet__subkey">read</span>: inspect files
  <span class="runtime-sheet__subkey">grep</span>: search code and logs
  <span class="runtime-sheet__subkey">glob</span>: enumerate paths
  <span class="runtime-sheet__subkey">edit</span>: update files in place
  <span class="runtime-sheet__subkey">bash</span>: run tests, builds, and scripts
  <span class="runtime-sheet__subkey">webfetch</span>: fetch documentation or URLs when needed
  <span class="runtime-sheet__subkey">task</span>: launch a focused subagent

<span class="runtime-sheet__key">permission</span>:
  <span class="runtime-sheet__subkey">read</span>: <span class="runtime-sheet__allow">allow</span>
  <span class="runtime-sheet__subkey">edit</span>: <span class="runtime-sheet__allow">allow</span>
  <span class="runtime-sheet__subkey">bash</span>:
    <span class="runtime-sheet__quoted">"git status"</span>: <span class="runtime-sheet__allow">allow</span>
    <span class="runtime-sheet__quoted">"pnpm test *"</span>: <span class="runtime-sheet__allow">allow</span>
    <span class="runtime-sheet__quoted">"rm *"</span>: <span class="runtime-sheet__deny">deny</span>
    <span class="runtime-sheet__quoted">"*"</span>: <span class="runtime-sheet__ask">ask</span>
  <span class="runtime-sheet__subkey">external_directory</span>: <span class="runtime-sheet__ask">ask</span>

<span class="runtime-sheet__key">loop</span>:
  <span class="runtime-sheet__item">-</span> inspect
  <span class="runtime-sheet__item">-</span> choose a tool
  <span class="runtime-sheet__item">-</span> observe the result
  <span class="runtime-sheet__item">-</span> update the plan
  <span class="runtime-sheet__item">-</span> continue until done or blocked</code></pre>
  </div>

  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .harness-runtime {
    margin: 2.75rem 0;
  }

  .runtime-sheet {
    border: 1px solid hsl(var(--border));
    border-radius: calc(var(--radius) + 0.05rem);
    background: hsl(var(--card));
  }

  .runtime-sheet__pre {
    margin: 0;
    padding: 1.05rem 1.12rem;
    color: hsl(var(--foreground));
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New",
      monospace;
    font-size: 0.82rem;
    line-height: 1.72;
    overflow-x: auto;
    white-space: pre;
  }

  .runtime-sheet__key {
    color: hsl(var(--foreground));
  }

  .runtime-sheet__subkey {
    color: rgb(176 196 220);
  }

  .runtime-sheet__item {
    color: hsl(var(--muted-foreground));
  }

  .runtime-sheet__path,
  .runtime-sheet__quoted {
    color: rgb(227 210 144);
  }

  .runtime-sheet__allow {
    color: rgb(176 218 188);
  }

  .runtime-sheet__ask {
    color: rgb(226 204 146);
  }

  .runtime-sheet__deny {
    color: rgb(227 182 182);
  }

  figcaption {
    margin-top: 0.95rem;
    color: hsl(var(--muted-foreground));
    font-size: 0.95rem;
    line-height: 1.55;
    text-align: center;
    font-style: normal;
  }

  @media (max-width: 768px) {
    .harness-runtime {
      margin: 2.25rem 0;
    }

    .runtime-sheet {
      border-radius: var(--radius);
    }

    .runtime-sheet__pre {
      padding: 0.92rem 0.95rem;
      font-size: 0.79rem;
      line-height: 1.68;
    }
  }
</style>

---
import WindowFrame from "./primitives/WindowFrame.astro";

interface Props {
  title: string;
  caption?: string;
  composer?: string;
}

const { title, caption, composer = "Message..." } = Astro.props;
---

<figure class="chat-figure">
  <WindowFrame title={title} composer={composer}>
    <slot />
  </WindowFrame>

  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .chat-figure {
    margin: 2.75rem 0;
  }

  figcaption {
    margin-top: 0.95rem;
    color: hsl(var(--muted-foreground));
    font-size: 0.95rem;
    line-height: 1.55;
    text-align: center;
    font-style: normal;
  }

  @media (max-width: 768px) {
    .chat-figure {
      margin: 2.25rem 0;
    }
  }
</style>

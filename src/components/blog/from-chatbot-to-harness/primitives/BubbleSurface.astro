---
interface Props {
  role?: "user" | "assistant";
  emphasis?: "normal" | "strong" | "muted";
}

const { role = "assistant", emphasis = "normal" } = Astro.props;
---

<div class:list={["bubble-surface", `bubble-surface--${role}`, `bubble-surface--${emphasis}`]}>
  <slot />
</div>

<style>
  .bubble-surface {
    --bubble-bg: #111214;
    --bubble-border: rgb(255 255 255 / 0.08);
    --bubble-text: rgb(237 237 240);
    --bubble-code-bg: rgb(255 255 255 / 0.05);
    --bubble-code-text: rgb(245 245 245);
    --bubble-opacity: 1;
    min-width: 0;
    overflow-wrap: anywhere;
    border: 1px solid var(--bubble-border);
    border-radius: 0.85rem;
    padding: 0.9rem 0.95rem;
    background: var(--bubble-bg);
    color: var(--bubble-text);
    font-size: 0.95rem;
    line-height: 1.58;
    box-shadow: none;
    opacity: var(--bubble-opacity);
  }

  .bubble-surface--user {
    --bubble-bg: rgb(245 245 245);
    --bubble-border: rgb(255 255 255 / 0.14);
    --bubble-text: rgb(17 17 19);
    --bubble-code-bg: rgb(228 228 231);
    --bubble-code-text: rgb(17 17 19);
  }

  .bubble-surface--strong {
    --bubble-border: rgb(255 255 255 / 0.18);
    box-shadow:
      0 0 0 1px rgb(255 255 255 / 0.03),
      inset 0 1px 0 rgb(255 255 255 / 0.02);
  }

  .bubble-surface--muted {
    --bubble-opacity: 0.64;
  }

  .bubble-surface :global(p),
  .bubble-surface :global(ul),
  .bubble-surface :global(ol) {
    margin: 0 0 0.7rem;
    color: var(--bubble-text);
    font-size: 0.95rem;
    line-height: 1.58;
  }

  .bubble-surface :global(:last-child) {
    margin-bottom: 0;
  }

  .bubble-surface :global(code) {
    padding: 0.1rem 0.35rem;
    border-radius: 0.3rem;
    background: var(--bubble-code-bg);
    color: var(--bubble-code-text);
    font-size: 0.92em;
    overflow-wrap: anywhere;
  }

  .bubble-surface :global(a) {
    color: inherit;
    text-decoration-color: rgb(255 255 255 / 0.28);
    text-underline-offset: 0.15em;
  }

  .bubble-surface :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 0.2rem 0 0;
    font-size: 0.86rem;
    line-height: 1.45;
  }

  .bubble-surface :global(th),
  .bubble-surface :global(td) {
    padding: 0.5rem 0.4rem;
    border-top: 1px solid rgb(255 255 255 / 0.1);
    text-align: left;
    vertical-align: top;
  }

  .bubble-surface :global(th) {
    color: rgb(196 196 201);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .bubble-surface--user :global(th),
  .bubble-surface--user :global(td) {
    border-top-color: rgb(17 17 19 / 0.12);
  }

  .bubble-surface--user :global(th) {
    color: rgb(82 82 91);
  }
</style>

---
interface Props {
  role?: "user" | "assistant";
  emphasis?: "normal" | "strong" | "muted";
}

const { role = "assistant", emphasis = "normal" } = Astro.props;
---

<div class:list={["bubble-surface", `bubble-surface--${role}`, `bubble-surface--${emphasis}`]}>
  <slot />
</div>

<style>
  .bubble-surface {
    --bubble-bg: hsl(var(--muted));
    --bubble-border: hsl(var(--border));
    --bubble-text: hsl(var(--foreground));
    --bubble-code-bg: hsl(var(--card));
    --bubble-code-text: hsl(var(--foreground));
    --bubble-opacity: 1;
    min-width: 0;
    overflow-wrap: anywhere;
    border: 1px solid var(--bubble-border);
    border-radius: calc(var(--radius) + 0.05rem);
    padding: 0.9rem 0.95rem;
    background: var(--bubble-bg);
    color: var(--bubble-text);
    font-size: 0.95rem;
    line-height: 1.58;
    box-shadow: none;
    opacity: var(--bubble-opacity);
  }

  .bubble-surface--user {
    --bubble-bg: hsl(var(--primary));
    --bubble-border: hsl(var(--primary));
    --bubble-text: hsl(var(--primary-foreground));
    --bubble-code-bg: hsl(var(--primary-foreground) / 0.12);
    --bubble-code-text: hsl(var(--primary-foreground));
  }

  .bubble-surface--strong {
    --bubble-border: hsl(var(--foreground) / 0.16);
  }

  .bubble-surface--muted {
    --bubble-opacity: 0.38;
  }

  .bubble-surface :global(p),
  .bubble-surface :global(ul),
  .bubble-surface :global(ol) {
    margin: 0 0 0.7rem;
    color: var(--bubble-text);
    font-size: 0.95rem;
    line-height: 1.58;
  }

  .bubble-surface :global(:last-child) {
    margin-bottom: 0;
  }

  .bubble-surface :global(code) {
    padding: 0.1rem 0.35rem;
    border-radius: 0.3rem;
    background: var(--bubble-code-bg);
    color: var(--bubble-code-text);
    font-size: 0.92em;
    overflow-wrap: anywhere;
  }

  .bubble-surface :global(a) {
    color: inherit;
    text-decoration-color: hsl(var(--foreground) / 0.25);
    text-underline-offset: 0.15em;
  }

  .bubble-surface :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 0.2rem 0 0;
    font-size: 0.86rem;
    line-height: 1.45;
  }

  .bubble-surface :global(th),
  .bubble-surface :global(td) {
    padding: 0.5rem 0.4rem;
    border-top: 1px solid hsl(var(--foreground) / 0.08);
    text-align: left;
    vertical-align: top;
  }

  .bubble-surface :global(th) {
    color: hsl(var(--muted-foreground));
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .bubble-surface--user :global(th),
  .bubble-surface--user :global(td) {
    border-top-color: hsl(var(--primary-foreground) / 0.16);
  }

  .bubble-surface--user :global(th) {
    color: hsl(var(--primary-foreground) / 0.72);
  }
</style>

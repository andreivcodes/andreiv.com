---
interface Props {
  title: string;
  composer?: string;
}

const { title, composer = "Message..." } = Astro.props;
---

<div class="chat-window">
  <header class="chat-window__header">
    <div class="chat-window__chrome" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>

    <div class="chat-window__title-group">
      <span class="chat-window__title">{title}</span>
    </div>
  </header>

  <div class="chat-window__body">
    <slot />
  </div>

  <footer class="chat-window__footer">
    <div class="chat-window__composer">
      <span class="chat-window__composer-text">{composer}</span>
    </div>
  </footer>
</div>

<style>
  .chat-window {
    overflow: hidden;
    border: 1px solid rgb(255 255 255 / 0.08);
    border-radius: 0.95rem;
    background: #0a0a0b;
    box-shadow:
      0 18px 40px rgb(0 0 0 / 0.26),
      inset 0 1px 0 rgb(255 255 255 / 0.03);
  }

  .chat-window__header {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem 1rem;
    border-bottom: 1px solid rgb(255 255 255 / 0.08);
    background: #0f0f10;
  }

  .chat-window__chrome {
    display: inline-flex;
    gap: 0.35rem;
  }

  .chat-window__chrome span {
    width: 0.58rem;
    height: 0.58rem;
    border-radius: 999px;
    background: rgb(255 255 255 / 0.18);
  }

  .chat-window__title-group {
    min-width: 0;
  }

  .chat-window__title {
    display: block;
    overflow-wrap: anywhere;
    color: rgb(245 245 245);
    font-size: 0.93rem;
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1.3;
  }

  .chat-window__body {
    display: grid;
    gap: 1rem;
    padding: 1.15rem;
    background: #0a0a0b;
  }

  .chat-window__footer {
    padding: 0.95rem 1rem 1rem;
    border-top: 1px solid rgb(255 255 255 / 0.08);
    background: #0f0f10;
  }

  .chat-window__composer {
    display: block;
    padding: 0.85rem 0.9rem;
    border: 1px solid rgb(255 255 255 / 0.08);
    border-radius: 0.7rem;
    background: #0b0b0c;
  }

  .chat-window__composer-text {
    overflow-wrap: anywhere;
    color: rgb(141 141 148);
    font-size: 0.92rem;
    line-height: 1.35;
  }

  @media (max-width: 768px) {
    .chat-window {
      border-radius: 0.8rem;
    }

    .chat-window__header {
      grid-template-columns: auto 1fr;
      gap: 0.8rem;
      padding: 0.95rem 1rem;
    }

    .chat-window__body {
      padding: 1rem;
    }

    .chat-window__footer {
      padding: 0.85rem 1rem 1rem;
    }

    .chat-window__composer {
      padding: 0.8rem 0.85rem;
    }
  }
</style>

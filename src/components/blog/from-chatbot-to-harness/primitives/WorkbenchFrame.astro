---
interface Props {
  title: string;
  path?: string;
  model?: string;
  status?: string;
}

const { title, path, model = "agent", status } = Astro.props;
---

<div class="workbench-frame">
  <header class="workbench-frame__header">
    <div class="workbench-frame__chrome" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>

    <div class="workbench-frame__title-group">
      <span class="workbench-frame__model">{model}</span>
      <span class="workbench-frame__title">{title}</span>
    </div>

    <div class="workbench-frame__meta">
      {path && <span class="workbench-frame__path">{path}</span>}
      {status && <span class="workbench-frame__status">{status}</span>}
    </div>
  </header>

  <div class="workbench-frame__body">
    <slot />
  </div>
</div>

<style>
  .workbench-frame {
    overflow: hidden;
    border: 1px solid rgb(255 255 255 / 0.08);
    border-radius: 0.72rem;
    background: #080809;
    box-shadow:
      0 20px 44px rgb(0 0 0 / 0.28),
      inset 0 1px 0 rgb(255 255 255 / 0.03);
  }

  .workbench-frame__header {
    display: grid;
    grid-template-columns: auto auto 1fr;
    align-items: center;
    gap: 0.9rem;
    padding: 0.74rem 0.9rem;
    border-bottom: 1px solid rgb(255 255 255 / 0.08);
    background: #0d0d0e;
  }

  .workbench-frame__chrome {
    display: inline-flex;
    gap: 0.34rem;
  }

  .workbench-frame__chrome span {
    width: 0.56rem;
    height: 0.56rem;
    border-radius: 999px;
    background: rgb(255 255 255 / 0.16);
  }

  .workbench-frame__title-group {
    display: inline-grid;
    gap: 0.14rem;
    min-width: 0;
  }

  .workbench-frame__model {
    color: rgb(148 148 154);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    line-height: 1;
    text-transform: uppercase;
  }

  .workbench-frame__title {
    overflow-wrap: anywhere;
    color: rgb(245 245 246);
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New",
      monospace;
    font-size: 0.84rem;
    font-weight: 500;
    line-height: 1.25;
  }

  .workbench-frame__meta {
    display: inline-flex;
    justify-self: end;
    align-items: center;
    gap: 0.55rem;
    min-width: 0;
  }

  .workbench-frame__path,
  .workbench-frame__status {
    overflow-wrap: anywhere;
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New",
      monospace;
    color: rgb(162 162 169);
    font-size: 0.72rem;
    line-height: 1.2;
  }

  .workbench-frame__status {
    color: rgb(228 228 232);
  }

  .workbench-frame__body {
    padding: 0.9rem;
    background: #080809;
  }

  @media (max-width: 768px) {
    .workbench-frame {
      border-radius: 0.66rem;
    }

    .workbench-frame__header {
      grid-template-columns: auto 1fr;
      gap: 0.8rem;
      padding: 0.74rem 0.84rem;
    }

    .workbench-frame__meta {
      grid-column: 1 / -1;
      justify-self: start;
      flex-wrap: wrap;
    }

    .workbench-frame__body {
      padding: 0.82rem;
    }
  }
</style>

---
import SectionLabel from "./SectionLabel.astro";

interface Props {
  label?: string;
  emphasis?: "normal" | "strong" | "muted";
}

const { label = "Thinking", emphasis = "normal" } = Astro.props;
---

<div class:list={["reasoning-trace", `reasoning-trace--${emphasis}`]}>
  <SectionLabel
    text={label}
    tone={emphasis === "strong" ? "strong" : emphasis === "muted" ? "muted" : "default"}
  />
  <div class="reasoning-trace__body">
    <slot />
  </div>
</div>

<style>
  .reasoning-trace {
    display: grid;
    gap: 0.6rem;
    max-width: 88%;
    padding: 0.95rem 1rem;
    border: 1px solid hsl(var(--border));
    border-left-width: 2px;
    border-left-color: hsl(var(--muted-foreground) / 0.5);
    border-radius: var(--radius);
    background: hsl(var(--muted));
  }

  .reasoning-trace--strong {
    border-color: hsl(var(--border));
    border-left-color: hsl(var(--foreground) / 0.34);
    background: hsl(var(--card));
  }

  .reasoning-trace--muted {
    opacity: 0.38;
  }

  .reasoning-trace__body {
    position: relative;
    padding-left: 1rem;
    color: hsl(var(--muted-foreground));
    font-size: 0.92rem;
    line-height: 1.52;
  }

  .reasoning-trace__body::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 0.4rem;
    background: radial-gradient(
        circle,
        hsl(var(--muted-foreground) / 0.58) 0 1px,
        transparent 1.4px
      )
      center top / 0.4rem 0.56rem repeat-y;
  }

  .reasoning-trace--strong .reasoning-trace__body::before {
    background: radial-gradient(circle, hsl(var(--foreground) / 0.82) 0 1px, transparent 1.4px)
      center top / 0.4rem 0.56rem repeat-y;
  }

  .reasoning-trace__body :global(ul),
  .reasoning-trace__body :global(ol) {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .reasoning-trace__body :global(li) {
    position: relative;
    margin: 0 0 0.55rem;
    padding-left: 0.8rem;
  }

  .reasoning-trace__body :global(li:last-child) {
    margin-bottom: 0;
  }

  .reasoning-trace__body :global(li)::before {
    content: "";
    position: absolute;
    top: 0.45rem;
    left: 0;
    width: 0.32rem;
    height: 0.32rem;
    border-radius: 999px;
    background: hsl(var(--foreground) / 0.7);
  }

  .reasoning-trace__body :global(p) {
    margin: 0 0 0.6rem;
  }

  .reasoning-trace__body :global(:last-child) {
    margin-bottom: 0;
  }
</style>

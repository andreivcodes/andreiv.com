---
import SectionLabel from "./SectionLabel.astro";

interface Props {
  label?: string;
  emphasis?: "normal" | "strong" | "muted";
}

const { label = "Thinking", emphasis = "normal" } = Astro.props;
---

<div class:list={["reasoning-trace", `reasoning-trace--${emphasis}`]}>
  <SectionLabel
    text={label}
    tone={emphasis === "strong" ? "strong" : emphasis === "muted" ? "muted" : "default"}
  />
  <div class="reasoning-trace__body">
    <slot />
  </div>
</div>

<style>
  .reasoning-trace {
    display: grid;
    gap: 0.6rem;
    max-width: 88%;
    padding: 0.95rem 1rem;
    border: 1px dashed rgb(255 255 255 / 0.14);
    border-radius: 0.75rem;
    background: #0f1011;
  }

  .reasoning-trace--strong {
    border-style: solid;
    border-color: rgb(255 255 255 / 0.16);
    background: #111214;
    box-shadow:
      0 0 0 1px rgb(255 255 255 / 0.03),
      inset 0 1px 0 rgb(255 255 255 / 0.02);
  }

  .reasoning-trace--muted {
    opacity: 0.62;
  }

  .reasoning-trace__body {
    position: relative;
    padding-left: 1rem;
    color: rgb(214 214 219);
    font-size: 0.92rem;
    line-height: 1.52;
  }

  .reasoning-trace__body::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0.15rem;
    width: 1px;
    background: repeating-linear-gradient(
      to bottom,
      rgb(161 161 170 / 0.8) 0,
      rgb(161 161 170 / 0.8) 4px,
      transparent 4px,
      transparent 9px
    );
  }

  .reasoning-trace--strong .reasoning-trace__body::before {
    background: linear-gradient(to bottom, rgb(231 231 235), rgb(112 112 120));
  }

  .reasoning-trace__body :global(ul),
  .reasoning-trace__body :global(ol) {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .reasoning-trace__body :global(li) {
    position: relative;
    margin: 0 0 0.55rem;
    padding-left: 0.8rem;
  }

  .reasoning-trace__body :global(li:last-child) {
    margin-bottom: 0;
  }

  .reasoning-trace__body :global(li)::before {
    content: "";
    position: absolute;
    top: 0.45rem;
    left: 0;
    width: 0.32rem;
    height: 0.32rem;
    border-radius: 999px;
    background: rgb(212 212 216);
  }

  .reasoning-trace__body :global(p) {
    margin: 0 0 0.6rem;
  }

  .reasoning-trace__body :global(:last-child) {
    margin-bottom: 0;
  }
</style>

---
import SectionLabel from "./SectionLabel.astro";

interface Props {
  label?: string;
  emphasis?: "normal" | "strong" | "muted";
}

const { label = "Tool Result", emphasis = "normal" } = Astro.props;
---

<div class:list={["tool-result", `tool-result--${emphasis}`]}>
  <SectionLabel
    text={label}
    tone={emphasis === "strong" ? "strong" : emphasis === "muted" ? "muted" : "default"}
  />
  <div class="tool-result__body">
    <slot />
  </div>
</div>

<style>
  .tool-result {
    display: grid;
    gap: 0.5rem;
    margin-left: 1.1rem;
    padding: 0.8rem 0.9rem;
    border: 1px solid hsl(var(--border));
    border-left-width: 2px;
    border-left-color: hsl(var(--muted-foreground) / 0.44);
    border-radius: var(--radius);
    background: hsl(var(--card));
  }

  .tool-result--strong {
    border-color: hsl(var(--foreground) / 0.14);
    border-left-width: 3px;
    border-left-color: hsl(var(--foreground) / 0.36);
  }

  .tool-result--muted {
    opacity: 0.38;
  }

  .tool-result__body {
    color: hsl(var(--muted-foreground));
    font-size: 0.93rem;
    line-height: 1.5;
  }

  .tool-result__body :global(p) {
    margin: 0 0 0.65rem;
  }

  .tool-result__body :global(:last-child) {
    margin-bottom: 0;
  }

  .tool-result__body :global(code) {
    padding: 0.08rem 0.32rem;
    border-radius: calc(var(--radius) - 0.2rem);
    background: hsl(var(--card));
    color: hsl(var(--foreground));
    font-size: 0.92em;
    overflow-wrap: anywhere;
  }

  .tool-result__body :global(pre) {
    margin: 0;
    padding: 0.75rem 0.8rem;
    border: 1px solid hsl(var(--border));
    border-radius: calc(var(--radius) - 0.1rem);
    background: hsl(var(--card));
    color: hsl(var(--foreground));
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New",
      monospace;
    font-size: 0.82rem;
    line-height: 1.55;
    overflow-x: auto;
    white-space: pre;
  }

  .tool-result__body :global(pre code) {
    display: block;
    padding: 0;
    border-radius: 0;
    background: transparent;
    color: inherit;
    font-size: inherit;
  }
</style>

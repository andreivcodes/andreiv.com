---
import SectionLabel from "./SectionLabel.astro";

interface Props {
  label?: string;
  emphasis?: "normal" | "strong" | "muted";
}

const { label = "System Prompt", emphasis = "normal" } = Astro.props;
---

<div class:list={["system-prompt-bar", `system-prompt-bar--${emphasis}`]}>
  <SectionLabel
    text={label}
    tone={emphasis === "strong" ? "strong" : emphasis === "muted" ? "muted" : "default"}
  />
  <div class="system-prompt-bar__body">
    <slot />
  </div>
</div>

<style>
  .system-prompt-bar {
    display: grid;
    gap: 0.55rem;
    padding: 0.8rem 0.9rem 0.85rem;
    border: 1px solid hsl(var(--border));
    border-radius: var(--radius);
    background: hsl(var(--muted));
  }

  .system-prompt-bar--strong {
    border-color: hsl(var(--foreground) / 0.16);
    background: hsl(var(--card));
  }

  .system-prompt-bar--muted {
    opacity: 0.38;
  }

  .system-prompt-bar__body {
    color: hsl(var(--muted-foreground));
    font-size: 0.9rem;
    line-height: 1.5;
    letter-spacing: 0;
  }

  .system-prompt-bar__body :global(p) {
    margin: 0;
  }

  .system-prompt-bar__body :global(ul),
  .system-prompt-bar__body :global(ol) {
    margin: 0;
    padding-left: 1.2rem;
    list-style-position: outside;
  }

  .system-prompt-bar__body :global(li) {
    margin: 0;
    padding-left: 0.1rem;
  }

  .system-prompt-bar__body :global(li + li) {
    margin-top: 0.3rem;
  }

  .system-prompt-bar__body :global(code) {
    padding: 0.08rem 0.32rem;
    border-radius: calc(var(--radius) - 0.2rem);
    background: hsl(var(--background));
    color: hsl(var(--foreground));
    font-size: 0.92em;
    overflow-wrap: anywhere;
  }
</style>

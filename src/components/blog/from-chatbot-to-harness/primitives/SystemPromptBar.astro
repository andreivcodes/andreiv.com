---
import SectionLabel from "./SectionLabel.astro";

interface Props {
  label?: string;
  emphasis?: "normal" | "strong" | "muted";
}

const { label = "System Prompt", emphasis = "normal" } = Astro.props;
---

<div class:list={["system-prompt-bar", `system-prompt-bar--${emphasis}`]}>
  <SectionLabel
    text={label}
    tone={emphasis === "strong" ? "strong" : emphasis === "muted" ? "muted" : "default"}
  />
  <div class="system-prompt-bar__body">
    <slot />
  </div>
</div>

<style>
  .system-prompt-bar {
    display: grid;
    gap: 0.55rem;
    padding: 0.8rem 0.9rem 0.85rem;
    border: 1px solid rgb(255 255 255 / 0.08);
    border-radius: 0.55rem;
    background: linear-gradient(180deg, rgb(255 255 255 / 0.04), rgb(255 255 255 / 0.01)), #0d0d0e;
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.03);
  }

  .system-prompt-bar--strong {
    border-color: rgb(255 255 255 / 0.16);
    background: linear-gradient(180deg, rgb(255 255 255 / 0.08), rgb(255 255 255 / 0.02)), #101012;
    box-shadow:
      0 0 0 1px rgb(255 255 255 / 0.03),
      inset 0 1px 0 rgb(255 255 255 / 0.05);
  }

  .system-prompt-bar--muted {
    opacity: 0.62;
  }

  .system-prompt-bar__body {
    color: rgb(201 201 206);
    font-size: 0.9rem;
    line-height: 1.5;
    letter-spacing: 0;
  }

  .system-prompt-bar__body :global(p) {
    margin: 0;
  }

  .system-prompt-bar__body :global(ul),
  .system-prompt-bar__body :global(ol) {
    margin: 0;
    padding-left: 1rem;
  }

  .system-prompt-bar__body :global(li + li) {
    margin-top: 0.3rem;
  }

  .system-prompt-bar__body :global(code) {
    padding: 0.08rem 0.32rem;
    border-radius: 0.3rem;
    background: rgb(255 255 255 / 0.05);
    color: rgb(244 244 246);
    font-size: 0.92em;
    overflow-wrap: anywhere;
  }
</style>

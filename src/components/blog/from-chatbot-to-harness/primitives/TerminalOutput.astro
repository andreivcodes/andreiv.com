---

---

<div class="terminal-output">
  <slot />
</div>

<style>
  .terminal-output {
    display: grid;
    gap: 0.38rem;
    padding: 0.15rem 0;
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New",
      monospace;
    font-size: 0.84rem;
    line-height: 1.48;
    color: hsl(var(--foreground));
  }

  .terminal-output :global(.terminal-line) {
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .terminal-output :global(.terminal-line--muted) {
    color: hsl(var(--muted-foreground));
  }

  .terminal-output :global(.terminal-line--success) {
    color: rgb(176 218 188);
  }

  .terminal-output :global(.terminal-line--error) {
    color: rgb(227 182 182);
  }

  .terminal-output :global(.terminal-prompt) {
    color: rgb(182 214 198);
  }

  .terminal-output :global(.terminal-command) {
    color: hsl(var(--foreground));
  }

  .terminal-output :global(.terminal-token) {
    font-weight: 500;
  }

  .terminal-output :global(.terminal-token--info) {
    color: rgb(165 196 231);
  }

  .terminal-output :global(.terminal-token--path) {
    color: rgb(227 210 144);
  }

  .terminal-output :global(.terminal-token--url) {
    color: rgb(156 205 234);
  }

  .terminal-output :global(.terminal-token--success) {
    color: rgb(176 218 188);
  }

  .terminal-output :global(.terminal-token--error) {
    color: rgb(227 182 182);
  }
</style>

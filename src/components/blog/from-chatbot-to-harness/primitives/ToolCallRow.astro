---
import SectionLabel from "./SectionLabel.astro";

interface Props {
  label?: string;
  emphasis?: "normal" | "strong" | "muted";
}

const { label = "Tool Call", emphasis = "normal" } = Astro.props;
---

<div class:list={["tool-row", "tool-row--call", `tool-row--${emphasis}`]}>
  <div class="tool-row__header">
    <SectionLabel
      text={label}
      tone={emphasis === "strong" ? "strong" : emphasis === "muted" ? "muted" : "default"}
    />
  </div>
  <div class="tool-row__body">
    <span class="tool-row__prompt" aria-hidden="true">›</span>
    <div class="tool-row__content">
      <slot />
    </div>
  </div>
</div>

<style>
  .tool-row {
    display: grid;
    gap: 0.45rem;
    padding: 0.75rem 0.9rem;
    border: 1px solid hsl(var(--border));
    border-radius: var(--radius);
    background: hsl(var(--muted));
  }

  .tool-row--strong {
    border-color: hsl(var(--foreground) / 0.16);
    background: hsl(var(--card));
  }

  .tool-row--muted {
    opacity: 0.38;
  }

  .tool-row__body {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: start;
    gap: 0.7rem;
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New",
      monospace;
  }

  .tool-row__prompt {
    color: hsl(var(--muted-foreground));
    font-size: 0.95rem;
    line-height: 1.45;
  }

  .tool-row__content {
    min-width: 0;
    overflow-wrap: anywhere;
    color: hsl(var(--foreground));
    font-size: 0.9rem;
    line-height: 1.45;
  }

  .tool-row__content :global(p) {
    margin: 0;
  }
</style>

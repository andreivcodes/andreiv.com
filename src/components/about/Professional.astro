---
import type { ResumeProfessionalEntry } from "@/lib/resume";

interface Props {
  entries: ResumeProfessionalEntry[];
  title?: string;
  titleAlign?: "left" | "center";
}

const { entries, title = "Professional Experience", titleAlign = "left" } = Astro.props;
---

<div class="flex flex-col gap-8">
  <h2 class:list={["text-2xl font-bold", titleAlign === "center" ? "text-center" : "text-left"]}>
    {title}
  </h2>
  <div>
    {
      entries.map((experience) => (
        <article class="mb-8 flex w-full flex-col items-end gap-2">
          <div class="text-sm">{experience.period}</div>
          <div class="-mr-2 h-px w-32 bg-current md:-mr-8" />
          <div class="site-card-shell w-full">
            <div class="w-full p-4 md:p-6">
              <div class="flex w-full flex-col gap-3">
                {experience.companyName && (
                  <div class="flex w-full flex-col gap-1 md:flex-row md:items-baseline md:justify-between md:gap-4">
                    <div class="font-semibold">{experience.companyName}</div>
                    {experience.companyAbout && (
                      <div class="text-muted-foreground font-mono text-xs md:text-right">
                        {experience.companyAbout}
                      </div>
                    )}
                  </div>
                )}
                {experience.role && <div class="text-start text-lg">{experience.role}</div>}
              </div>
            </div>
            <div class="max-w-none px-4 pb-4 text-sm md:px-6 md:pb-6 [&>li]:mb-2 [&>ol]:mb-4 [&>ol]:pl-6 [&>p]:mb-4 [&>p]:leading-relaxed [&>ul]:mb-4 [&>ul]:pl-6">
              <Fragment set:html={experience.html} />
            </div>
          </div>
        </article>
      ))
    }
  </div>
</div>

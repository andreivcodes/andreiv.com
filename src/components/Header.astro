---
const currentPath = Astro.url.pathname;

function isCurrent(href: string) {
  return currentPath === href || (href !== "/" && currentPath.startsWith(`${href}/`));
}

function navLinkClass(href: string) {
  return ["site-nav-link", isCurrent(href) ? "site-nav-link-current" : ""]
    .filter(Boolean)
    .join(" ");
}
---

<header class="bg-muted/30 border-b font-mono backdrop-blur-sm">
  <nav
    aria-label="Primary"
    class="flex w-full flex-row items-center justify-between px-4 py-4 md:justify-around"
  >
    <div class="hidden w-1/4 flex-row justify-start md:flex">
      <a href="/" class="site-emphasis-link">andreiv's website</a>
    </div>

    <div class="flex items-center justify-center md:hidden">
      <a
        href="/"
        class="site-icon-link border-transparent bg-transparent p-1.5"
        aria-label="Go to homepage"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-6 w-6"
          aria-hidden="true"
        >
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
          <polyline points="9 22 9 12 15 12 15 22"></polyline>
        </svg>
      </a>
    </div>

    <div class="flex h-8 flex-row items-center justify-center gap-4 md:gap-8">
      <a
        href="/about"
        class={navLinkClass("/about")}
        aria-current={isCurrent("/about") ? "page" : undefined}>about</a
      >
      <div class="bg-border h-full w-[1px] shrink-0" aria-hidden="true"></div>
      <a
        href="/blog"
        class={navLinkClass("/blog")}
        aria-current={isCurrent("/blog") ? "page" : undefined}>blog</a
      >
      <div class="bg-border h-full w-[1px] shrink-0" aria-hidden="true"></div>
      <a
        href="/projects"
        class={navLinkClass("/projects")}
        aria-current={isCurrent("/projects") ? "page" : undefined}>projects</a
      >
    </div>

    <div class="hidden w-1/4 flex-row justify-end md:flex"></div>
  </nav>
</header>

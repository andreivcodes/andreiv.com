---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { Badge } from "@/components/ui/badge";
import { getProjects } from "@/lib/content";
import { STATIC_PAGE_METADATA } from "@/lib/pageMetadata";
import { ArrowRight, Calendar, ExternalLink } from "lucide-react";
import { GitHubLogoIcon } from "@radix-ui/react-icons";

const { title, description } = STATIC_PAGE_METADATA.projects;

const projects = await getProjects();
const sortedProjects = projects.sort((a, b) => (a.index || 999) - (b.index || 999));
const featuredProject = sortedProjects.find((project) => project.featuredImage);
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    {
      featuredProject?.featuredImage && (
        <link rel="preload" as="image" href={featuredProject.featuredImage} />
      )
    }
  </Fragment>

  <div class="flex min-h-screen flex-col">
    <Header />
    <main id="main-content" class="bg-background flex-1">
      <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
        <div class="mb-16 text-center">
          <h1 class="mb-4 text-4xl font-bold md:text-5xl">Projects</h1>
          <p class="text-muted-foreground mx-auto max-w-2xl text-lg">
            A collection of projects and experiments I've been working on.
          </p>
        </div>

        <div class="space-y-12 lg:space-y-16">
          {
            sortedProjects.map((project, index) => (
              <article class="relative overflow-hidden rounded-lg">
                <div class="site-card-shell relative flex flex-col overflow-hidden xl:grid xl:grid-cols-2">
                  <div class="relative overflow-hidden xl:order-2">
                    <div class="bg-muted/20 relative aspect-[16/9] w-full">
                      {project.featuredImage ? (
                        <img
                          src={project.featuredImage}
                          alt={`${project.name} preview`}
                          class="h-full w-full object-cover"
                          loading={index === 0 ? "eager" : "lazy"}
                          width="800"
                          height="450"
                        />
                      ) : (
                        <div class="from-muted via-muted/80 to-background flex h-full w-full items-center justify-center bg-gradient-to-br">
                          <div class="text-muted-foreground/10 text-7xl font-bold">
                            {project.name.slice(0, 2).toUpperCase()}
                          </div>
                        </div>
                      )}
                    </div>
                  </div>

                  <div class="flex flex-col p-8 xl:order-1 xl:min-h-[300px]">
                    <div>
                      <div class="mb-6">
                        <h2 class="-mt-1 mb-3 text-3xl font-bold xl:text-4xl">
                          <a href={`/projects/${project.slug}`} class="site-emphasis-link">
                            {project.name}
                          </a>
                        </h2>
                        <div class="text-muted-foreground flex items-center gap-2 text-sm">
                          <Calendar className="h-4 w-4" />
                          <time datetime={project.date}>{project.date}</time>
                        </div>
                      </div>

                      <p class="text-muted-foreground mb-8 text-lg leading-relaxed">
                        {project.shortDescription}
                      </p>

                      <div class="flex flex-wrap gap-2">
                        {project.stackPrimary?.map((tech: string) => (
                          <Badge
                            variant="default"
                            className="text-xs px-2 py-1 rounded-full pointer-events-none"
                          >
                            {tech}
                          </Badge>
                        ))}
                        {project.stackSecondary?.map((tech: string) => (
                          <Badge
                            variant="secondary"
                            className="text-xs px-2 py-1 rounded-full pointer-events-none"
                          >
                            {tech}
                          </Badge>
                        ))}
                      </div>
                    </div>

                    <div class="mt-auto flex flex-col gap-4 pt-8 sm:flex-row sm:items-center sm:justify-between">
                      <div class="flex items-center gap-4">
                        {project.url && (
                          <a
                            href={project.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="site-inline-link inline-flex items-center gap-1.5 text-sm"
                            aria-label={`View ${project.name} live demo`}
                          >
                            <ExternalLink className="h-4 w-4" />
                            <span>Demo</span>
                          </a>
                        )}
                        {project.repository && (
                          <a
                            href={project.repository}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="site-inline-link inline-flex items-center gap-1.5 text-sm"
                            aria-label={`View ${project.name} source code`}
                          >
                            <GitHubLogoIcon className="h-4 w-4" />
                            <span>Code</span>
                          </a>
                        )}
                      </div>

                      <a
                        href={`/projects/${project.slug}`}
                        class="site-emphasis-link group/link inline-flex items-center gap-1.5 text-sm font-medium"
                      >
                        <span>View Project</span>
                        <ArrowRight className="h-4 w-4 transition-transform duration-200 group-hover/link:translate-x-1 group-focus-visible/link:translate-x-1" />
                      </a>
                    </div>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </main>
    <Footer />
  </div>
</BaseLayout>

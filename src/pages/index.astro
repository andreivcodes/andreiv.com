---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { AboutShort } from "@/components/about-short";
import { STATIC_PAGE_METADATA } from "@/lib/pageMetadata";
import { getPersonStructuredData, getWebsiteStructuredData } from "@/lib/structuredData";

const { title, description } = STATIC_PAGE_METADATA.home;
const structuredData = [
  getWebsiteStructuredData(),
  getPersonStructuredData({
    pathname: "/",
    description,
  }),
];
---

<BaseLayout title={title} description={description} structuredData={structuredData}>
  <div class="flex min-h-screen flex-col">
    <Header />
    <main
      id="main-content"
      class="flex h-full w-full flex-1 flex-col items-center justify-evenly gap-4 py-8"
    >
      <div class="flex flex-col gap-2">
        <AboutShort client:load />
      </div>
    </main>
    <Footer />
  </div>
</BaseLayout>

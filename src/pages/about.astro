---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import AboutCombined from "@/components/about/AboutCombined.astro";
import AboutTimeline from "@/components/about/AboutTimeline.astro";
import { STATIC_PAGE_METADATA } from "@/lib/pageMetadata";
import { getResumeEntries } from "@/lib/resume";
import { getPersonStructuredData } from "@/lib/structuredData";
import { Download } from "lucide-react";

const { title, description } = STATIC_PAGE_METADATA.about;

const { professional, education } = await getResumeEntries();
const structuredData = getPersonStructuredData({
  pathname: "/about",
  description,
});
---

<BaseLayout title={title} description={description} structuredData={structuredData}>
  <div class="flex min-h-screen flex-col">
    <Header />
    <main id="main-content" class="flex flex-1 justify-center">
      <div class="flex h-full w-full max-w-7xl flex-col gap-10 p-4 md:gap-20 md:p-8">
        <div class="w-full">
          <AboutCombined />
        </div>

        <AboutTimeline professional={professional} education={education} />
      </div>
    </main>
    <a href="/resume" class="site-action-chip fixed right-6 bottom-6 z-50 sm:right-8 sm:bottom-8">
      <Download className="h-4 w-4" />
      <span>Download Resume</span>
    </a>
    <Footer />
  </div>
</BaseLayout>
